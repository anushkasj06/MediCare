NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_SECRET=replace_with_a_second_long_random_secret
JWT_EMAIL_EXPIRY=1d

# Frontend and backend public URLs
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_PUBLIC_URL=https://your-backend.onrender.com

# Cloudinary (optional if using local disk for uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Hospital App <no-reply@hospital.com>

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_DEFAULT_COUNTRY_CODE=+91
TWILIO_VOICE_URL=https://your-backend.onrender.com/api/automation/twiml/reminder
TWILIO_STATUS_CALLBACK_URL=https://your-backend.onrender.com/api/automation/twilio/status

# n8n Webhook (optional)
N8N_WEBHOOK_URL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Reminder cron
REMINDER_DISPATCH_CRON=* * * * *
