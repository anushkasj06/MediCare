pipeline {
  agent any
  options {
    ansiColor('xterm')
    timestamps()
  }
  environment {
    NODE_ENV = 'production'
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    stage('Install Dependencies') {
      steps {
        dir('backend') {
          script {
            if (isUnix()) {
              sh 'npm install'
            } else {
              bat 'npm install'
            }
          }
        }
      }
    }
    stage('Package Backend Artifact') {
      steps {
        dir('backend') {
          script {
            if (isUnix()) {
              sh 'zip -r ../backend-artifact.zip . -x node_modules/** -x .git/**'
            } else {
              bat 'powershell -Command "Compress-Archive -Path * -DestinationPath ..\\backend-artifact.zip -Force -Exclude node_modules, .git"'
            }
          }
        }
      }
    }
  }
  post {
    always {
      archiveArtifacts artifacts: 'backend-artifact.zip', fingerprint: true
      cleanWs()
    }
  }
}
