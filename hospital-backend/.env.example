NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://anushkasjadhav1_db_user:anushkasjadhav1_db_user@cluster0.b6poakk.mongodb.net/hospital_db?appName=Cluster0

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_SECRET=your_email_jwt_secret_key_change_in_prod
JWT_EMAIL_EXPIRY=1d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Nodemailer / Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Hospital App <your_email@gmail.com>"

# Twilio (SMS & Voice)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VOICE_URL=https://your-domain.com/api/automation/twiml/reminder

# n8n Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
