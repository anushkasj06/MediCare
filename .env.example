# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=password

# Node Environment
NODE_ENV=production

# Backend Configuration
BACKEND_PORT=5000
BACKEND_PUBLIC_URL=http://localhost:5000

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000,http://localhost:5173
VITE_API_BASE_URL=http://localhost:5000

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EMAIL_SECRET=your-super-secret-jwt-email-key-change-this-in-production

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@hospital.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+your-twilio-phone-number
TWILIO_DEFAULT_COUNTRY_CODE=+91
TWILIO_VOICE_URL=https://your-domain.com/twilio/voice
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/twilio/callback
